{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "Dotnetstore.DocumentViewer",
    "Audience": "Dotnetstore.DocumentViewer.Clients",
    "SigningKey": "",
    "AccessTokenLifetime": "00:15:00",
    "RefreshTokenLifetime": "14.00:00:00"
  },
  "ApiKey": {
    "Value": ""
  },
  "Seed": {
    "Admin": {
      "Email": "",
      "Password": "",
      "DisplayName": "Administrator"
    }
  },
  "DocumentStorage": {
    "RootPath": "",
    "MaxBytes": 104857600
  },
  "SignedUrl": {
    "SigningKey": "",
    "Lifetime": "00:01:00"
  },
  "DocumentConversion": {
    "Mode": "Gotenberg",
    "PollInterval": "00:00:05",
    "ConversionTimeout": "00:02:00",
    "Soffice": {
      "SofficePath": "soffice"
    },
    "Gotenberg": {
      "BaseAddress": "http://gotenberg"
    }
  },
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 10,
      "Window": "00:01:00"
    }
  }
}
