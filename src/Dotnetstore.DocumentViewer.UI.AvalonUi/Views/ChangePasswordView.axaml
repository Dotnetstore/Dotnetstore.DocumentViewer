<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.ChangePasswordView"
             x:DataType="vm:ChangePasswordViewModel">

    <Grid Background="{DynamicResource SemiColorBackground1}">
        <Border Classes="Card" Width="440" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Change password" Classes="Hero" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pick something memorable but at least 8 characters." Classes="Subtle"
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <Border CornerRadius="8" Padding="14,12"
                        Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1"
                        IsVisible="{Binding MustChangePassword}">
                    <TextBlock Text="An administrator set this password — please change it before continuing."
                               Foreground="#7A5A00" TextWrapping="Wrap"/>
                </Border>

                <StackPanel Spacing="10">
                    <TextBox Text="{Binding CurrentPassword, Mode=TwoWay}" Watermark="Current password" PasswordChar="●"/>
                    <TextBox Text="{Binding NewPassword, Mode=TwoWay}" Watermark="New password (min 8 chars)" PasswordChar="●"/>
                    <TextBox Text="{Binding ConfirmNewPassword, Mode=TwoWay}" Watermark="Confirm new password" PasswordChar="●"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Submit" Classes="Primary"
                            Command="{Binding SubmitCommand}" Padding="22,8"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding !MustChangePassword}" Padding="20,8"/>
                    <ProgressBar IsIndeterminate="True" Width="120" VerticalAlignment="Center"
                                 IsVisible="{Binding IsBusy}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Classes="StatusOk" TextWrapping="Wrap"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding ErrorMessage}" Classes="StatusError" TextWrapping="Wrap"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
