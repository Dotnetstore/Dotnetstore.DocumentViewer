<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.ChangePasswordView"
             x:DataType="vm:ChangePasswordViewModel">

    <StackPanel Margin="32" Spacing="10" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Change password" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <Border Background="#FFF4D6" Padding="10" CornerRadius="4"
                IsVisible="{Binding MustChangePassword}">
            <TextBlock Text="An administrator set this password — please change it now to continue."
                       TextWrapping="Wrap" Foreground="#664500"/>
        </Border>

        <TextBox Text="{Binding CurrentPassword, Mode=TwoWay}" Watermark="Current password" PasswordChar="●"/>
        <TextBox Text="{Binding NewPassword, Mode=TwoWay}" Watermark="New password" PasswordChar="●"/>
        <TextBox Text="{Binding ConfirmNewPassword, Mode=TwoWay}" Watermark="Confirm new password" PasswordChar="●"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Submit" Command="{Binding SubmitCommand}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    IsEnabled="{Binding !MustChangePassword}"/>
            <ProgressBar IsIndeterminate="True" Width="120" IsVisible="{Binding IsBusy}"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" Foreground="ForestGreen"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Crimson" TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>
</UserControl>
