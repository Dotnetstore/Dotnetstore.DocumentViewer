<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:dto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Audit"
             xmlns:conv="using:Dotnetstore.DocumentViewer.UI.AvalonUi.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.DocumentAuditLogView"
             x:DataType="vm:DocumentAuditLogViewModel">

    <Grid Background="{DynamicResource SemiColorBackground1}" RowDefinitions="Auto,*,Auto" Margin="32,24">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Audit log" Classes="Hero"/>
                <TextBlock Text="Every access attempt against this document — successful, denied, or blocked."
                           Classes="Subtle"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="120" IsVisible="{Binding IsBusy}"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                <Button Content="Back" Command="{Binding BackCommand}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Classes="Card" Padding="8">
            <Panel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                            IsVisible="{Binding Entries.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                    <TextBlock Text="No audit entries" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Once anyone tries to view this document, the attempt shows up here."
                               Classes="Subtle" HorizontalAlignment="Center"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Entries}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="dto:AuditLogEntryDto">
                            <Grid ColumnDefinitions="160,200,180,60,140,Auto" Margin="4,4" ColumnSpacing="12">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding AtUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                           FontFamily="Consolas,monospace" Classes="Meta" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserEmail, FallbackValue=—, TargetNullValue=—}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding Action}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding ResultCode}" VerticalAlignment="Center"
                                           Foreground="{Binding ResultCode, Converter={x:Static conv:HttpStatusColorConverter.Instance}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="{Binding IpAddress}" FontFamily="Consolas,monospace" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5"
                                           Text="{Binding PageNumber, StringFormat='Page {0}'}"
                                           Classes="Meta" VerticalAlignment="Center"
                                           IsVisible="{Binding PageNumber, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </Border>

        <Border Grid.Row="2" Margin="0,12,0,0"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" Classes="StatusError" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
