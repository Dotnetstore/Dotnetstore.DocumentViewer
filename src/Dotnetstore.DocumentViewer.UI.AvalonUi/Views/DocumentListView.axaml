<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:dto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Documents"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.DocumentListView"
             x:DataType="vm:DocumentListViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Documents" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Content="Delete"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding SelectedDocument}"
                    Foreground="Crimson"
                    IsVisible="{Binding IsAdmin}"
                    IsEnabled="{Binding SelectedDocument, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            <ProgressBar IsIndeterminate="True" Width="120" IsVisible="{Binding IsBusy}" />
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Documents}"
                 SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                 DoubleTapped="OnDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="dto:DocumentDto">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding OriginalFileName}" FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Audit log" Padding="10,4"
                                Command="{Binding $parent[ListBox].((vm:DocumentListViewModel)DataContext).ViewAuditLogCommand}"
                                CommandParameter="{Binding}"
                                IsVisible="{Binding $parent[ListBox].((vm:DocumentListViewModel)DataContext).IsAdmin}"/>
                        <Button Grid.Column="2" Content="Allowed IPs" Padding="10,4"
                                Command="{Binding $parent[ListBox].((vm:DocumentListViewModel)DataContext).ManageIpsCommand}"
                                CommandParameter="{Binding}"
                                IsVisible="{Binding $parent[ListBox].((vm:DocumentListViewModel)DataContext).IsAdmin}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Crimson"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   TextWrapping="Wrap" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
