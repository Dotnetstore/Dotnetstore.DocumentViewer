<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.UploadDocumentView"
             x:DataType="vm:UploadDocumentViewModel">

    <StackPanel Margin="32" Spacing="12" Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Upload document" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <TextBlock Text="PDF is stored as-is; DOCX is converted to PDF server-side via Gotenberg."
                   Opacity="0.7" TextWrapping="Wrap" HorizontalAlignment="Center"/>

        <TextBox Text="{Binding Title, Mode=TwoWay}" Watermark="Document title"/>

        <Border BorderBrush="#22000000" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Pick file…" Click="OnPickFileClick" x:Name="PickFileButton"/>
                    <Button Content="Clear" Command="{Binding ClearFileCommand}"
                            IsVisible="{Binding HasSelectedFile}"/>
                </StackPanel>
                <TextBlock Text="No file selected." Opacity="0.6"
                           IsVisible="{Binding !HasSelectedFile}"/>
                <StackPanel IsVisible="{Binding HasSelectedFile}">
                    <TextBlock>
                        <Run Text="File: "/><Run Text="{Binding SelectedFileName}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Type: "/><Run Text="{Binding SelectedContentType}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Size: "/><Run Text="{Binding SelectedFileSize}"/><Run Text=" bytes"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Upload"
                    Command="{Binding UploadCommand}"
                    IsEnabled="{Binding UploadCommand.CanExecute}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            <ProgressBar IsIndeterminate="True" Width="160" IsVisible="{Binding IsBusy}"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" Foreground="ForestGreen" TextWrapping="Wrap"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Crimson" TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>
</UserControl>
