<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:dto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Users"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.AdminUsersView"
             x:DataType="vm:AdminUsersViewModel">

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="2*,3*" Margin="16">
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Users" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="New user" Command="{Binding NewCommand}"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
            <ProgressBar IsIndeterminate="True" Width="120" IsVisible="{Binding IsBusy}"/>
        </StackPanel>

        <ListBox Grid.Row="1" Grid.Column="0"
                 ItemsSource="{Binding Users}"
                 SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                 Margin="0,0,12,0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="dto:UserDto">
                    <StackPanel>
                        <TextBlock Text="{Binding Email}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DisplayName}" Opacity="0.8"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="1" Grid.Column="1"
                BorderBrush="#22000000" BorderThickness="1" CornerRadius="6" Padding="16"
                IsVisible="{Binding IsEditing}">
            <StackPanel Spacing="10">
                <TextBlock Text="Edit user" FontWeight="SemiBold" FontSize="16"
                           IsVisible="{Binding !IsCreatingNew}"/>
                <TextBlock Text="Create user" FontWeight="SemiBold" FontSize="16"
                           IsVisible="{Binding IsCreatingNew}"/>

                <TextBox Text="{Binding FormEmail, Mode=TwoWay}" Watermark="Email"
                         IsEnabled="{Binding IsCreatingNew}"/>
                <TextBox Text="{Binding FormDisplayName, Mode=TwoWay}" Watermark="Display name"/>
                <TextBox Text="{Binding FormPassword, Mode=TwoWay}" Watermark="Initial password (only for new users)"
                         PasswordChar="●" IsEnabled="{Binding IsCreatingNew}"/>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox Content="Admin" IsChecked="{Binding FormIsAdmin, Mode=TwoWay}"/>
                    <CheckBox Content="Viewer" IsChecked="{Binding FormIsViewer, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Save" Command="{Binding SaveCommand}"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Foreground="Crimson"
                            IsVisible="{Binding !IsCreatingNew}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                   Text="{Binding ErrorMessage}" Foreground="Crimson" TextWrapping="Wrap" Margin="0,8,0,0"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </Grid>
</UserControl>
