<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:accessDto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Access"
             xmlns:docDto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Documents"
             xmlns:userDto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Users"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.AdminAccessView"
             x:DataType="vm:AdminAccessViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Document access" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
            <ProgressBar IsIndeterminate="True" Width="120" IsVisible="{Binding IsBusy}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Document:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Documents}"
                      SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                      Width="420">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="docDto:DocumentDto">
                        <TextBlock Text="{Binding Title}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Grants}"
                 SelectedItem="{Binding SelectedGrant, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="accessDto:DocumentAccessDto">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding UserEmail}" FontWeight="SemiBold" Width="280"/>
                        <TextBlock Text="{Binding GrantedAtUtc}" Opacity="0.7"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <TextBlock Text="Grant to:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding AvailableUsers}"
                      SelectedItem="{Binding UserToGrant, Mode=TwoWay}"
                      Width="320">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="userDto:UserDto">
                        <TextBlock Text="{Binding Email}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Grant" Command="{Binding GrantCommand}"/>
            <Button Content="Revoke selected" Command="{Binding RevokeCommand}" Foreground="Crimson"/>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="{Binding ErrorMessage}" Foreground="Crimson" TextWrapping="Wrap" Margin="0,8,0,0"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </Grid>
</UserControl>
