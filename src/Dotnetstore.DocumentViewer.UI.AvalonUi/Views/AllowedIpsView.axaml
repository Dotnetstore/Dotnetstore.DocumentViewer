<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dotnetstore.DocumentViewer.UI.AvalonUi.ViewModels"
             xmlns:dto="using:Dotnetstore.DocumentViewer.Shared.SDK.Dtos.Access"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.Views.AllowedIpsView"
             x:DataType="vm:AllowedIpsViewModel">

    <Grid Background="{DynamicResource SemiColorBackground1}" RowDefinitions="Auto,Auto,*,Auto" Margin="32,24">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Allowed IPs" Classes="Hero"/>
                <TextBlock Text="Only IPs / CIDRs on this list may render the document. Admins always bypass."
                           Classes="Subtle"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="120" IsVisible="{Binding IsBusy}"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                <Button Content="Back" Command="{Binding BackCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Add row -->
        <Border Grid.Row="1" Classes="CardCompact" Margin="0,0,0,16">
            <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0"
                         Watermark="CIDR or IP (e.g. 10.0.0.0/8, 203.0.113.5)"
                         Text="{Binding NewCidr, Mode=TwoWay}"/>
                <TextBox Grid.Column="1"
                         Watermark="Description (optional)"
                         Text="{Binding NewDescription, Mode=TwoWay}"/>
                <Button Grid.Column="2" Classes="Primary" Content="Add"
                        Command="{Binding AddCommand}" Padding="18,8"/>
            </Grid>
        </Border>

        <!-- List -->
        <Border Grid.Row="2" Classes="Card" Padding="8">
            <Panel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                            IsVisible="{Binding Entries.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                    <TextBlock Text="No allowed IPs" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Add at least one IP / CIDR above; until then, viewers cannot render this document."
                               Classes="Subtle" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Entries}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="dto:AllowedIpDto">
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="4,4">
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Cidr}" FontWeight="SemiBold" FontFamily="Consolas,monospace"/>
                                    <TextBlock Text="{Binding Description}" Classes="Meta"
                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding AddedAtUtc, StringFormat='Added {0:yyyy-MM-dd HH:mm} UTC'}"
                                           Classes="Meta" VerticalAlignment="Center" Margin="12,0"/>
                                <Button Grid.Column="2" Classes="Danger" Content="Remove"
                                        Command="{Binding $parent[ListBox].((vm:AllowedIpsViewModel)DataContext).RemoveCommand}"
                                        CommandParameter="{Binding}" Padding="12,4"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" Classes="StatusError" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
