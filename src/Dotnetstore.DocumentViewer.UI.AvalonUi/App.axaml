<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Dotnetstore.DocumentViewer.UI.AvalonUi.App"
             xmlns:local="using:Dotnetstore.DocumentViewer.UI.AvalonUi"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <semi:SemiTheme Locale="en-US"/>
        <StyleInclude Source="avares://Dotnetstore.DocumentViewer.UI.AvalonUi/Styles/AppStyles.axaml"/>
    </Application.Styles>
</Application>
