# Copy to .env and replace every value before running `docker compose up`.
# The .env file is gitignored.

# Postgres superuser password (also used as the documentviewer DB password).
POSTGRES_PASSWORD=change-me-postgres-password

# JWT signing key — MUST be at least 32 characters; arbitrary entropy is fine.
# `openssl rand -base64 48` is a good source.
JWT_SIGNING_KEY=change-me-jwt-key-must-be-at-least-32-characters-long

# Signed-URL HMAC key — same length / entropy guidance as JWT_SIGNING_KEY.
SIGNED_URL_SIGNING_KEY=change-me-signed-url-key-must-be-at-least-32-characters

# ApiKey middleware compares this against the X-Api-Key request header.
# Treat as a shared secret between the WebApi and the Avalonia client build.
API_KEY=change-me-api-key

# Seeded admin. Created on first boot if no admin exists in the DB.
# MustChangePassword is set to true so the first login forces a password change.
SEED_ADMIN_EMAIL=admin@dotnetstore.local
SEED_ADMIN_PASSWORD=ChangeMeOnFirstLogin123!
